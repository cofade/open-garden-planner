{
  "id": "raised_bed_rows",
  "version": 1,
  "name": "Raised Bed (rows)",
  "name_de": "Hochbeet (Reihen)",
  "category": "beds",
  "parameters": [
    {"name": "L", "type": "length", "label": "Length", "label_de": "Länge", "default": 200, "min": 20, "max": 1000, "unit": "cm"},
    {"name": "W", "type": "length", "label": "Width", "label_de": "Breite", "default": 100, "min": 20, "max": 500, "unit": "cm"},
    {"name": "rows", "type": "number", "label": "Rows", "label_de": "Reihen", "default": 4, "min": 1, "max": 20}
  ],
  "elements": [
    {"kind": "rect", "x": 0, "y": 0, "w": "L", "h": "W", "object_type": "RAISED_BED"},
    {"repeat": {"var": "i", "from": 1, "to": "rows - 1"},
     "element": {"kind": "line", "x1": 0, "y1": "W * i / rows", "x2": "L", "y2": "W * i / rows"}}
  ]
}
